APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_CUSTOM_PORT=8088
APP_URL="http://0.0.0.0:${APP_CUSTOM_PORT}"
VITE_HMR_HOST=192.168.56.104

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db  # Имя контейнера базы данных из docker-compose
DB_PORT=3306
DB_DATABASE=blog
DB_USERNAME=lara_user
DB_PASSWORD=your_user_password

BROADCAST_DRIVER=reverb
BROADCAST_CONNECTION=reverb

CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
#QUEUE_CONNECTION=sync # работа синхронно без бд/очереди
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="0.0.0.0"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${VITE_HMR_HOST}"
VITE_REVERB_PORT="${APP_CUSTOM_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
